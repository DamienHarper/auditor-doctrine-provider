{
  "name": "damienharper/auditor-doctrine-provider",
  "type": "library",
  "description": "Doctrine ORM provider for the auditor audit-log library.",
  "keywords": ["doctrine", "audit", "audit-log", "audit-trail"],
  "license": "MIT",
  "authors": [
    {
      "name": "Damien Harper",
      "email": "damien.harper@gmail.com"
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require": {
    "php": ">=8.4",
    "damienharper/auditor": "^5.0@dev",
    "doctrine/dbal": "^4.0",
    "doctrine/orm": "^3.2",
    "symfony/cache": "^8.0",
    "symfony/lock": "^8.0"
  },
  "suggest": {
    "damienharper/auditor-bundle": "Integrate auditor library in your Symfony projects.",
    "gedmo/doctrine-extensions": "Required for soft-delete support."
  },
  "autoload": {
    "psr-4": {
      "DH\\Auditor\\Provider\\Doctrine\\": "src/Provider/Doctrine"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "DH\\Auditor\\Tests\\": "tests",
      "DH\\Auditor\\Provider\\Doctrine\\Benchmarks\\": "benchmarks"
    }
  },
  "require-dev": {
    "ext-pdo": "*",
    "doctrine/data-fixtures": "^2.0",
    "gedmo/doctrine-extensions": "^3.0",
    "phpbench/phpbench": "^1.4",
    "phpunit/phpunit": "^12.0",
    "symfony/flex": "^2.4",
    "symfony/var-dumper": "^8.0"
  },
  "scripts": {
    "test": "./vendor/bin/phpunit --colors=always --no-coverage",
    "test:coverage": "XDEBUG_MODE=coverage ./vendor/bin/phpunit --colors=always",
    "testdox": "./vendor/bin/phpunit --colors=always --testdox --no-coverage",
    "cs-fix": "tools/php-cs-fixer/vendor/bin/php-cs-fixer fix --using-cache=no --verbose --ansi --allow-unsupported-php-version=yes",
    "cs-check": "tools/php-cs-fixer/vendor/bin/php-cs-fixer fix --using-cache=no --verbose --ansi --dry-run --allow-unsupported-php-version=yes",
    "phpstan": "tools/phpstan/vendor/bin/phpstan --memory-limit=1G --ansi analyse",
    "rector": "tools/rector/vendor/bin/rector",
    "rector-check": "tools/rector/vendor/bin/rector --dry-run",
    "qa": [
      "@rector",
      "@cs-fix",
      "@phpstan"
    ],
    "bench": "vendor/bin/phpbench run benchmarks/AuditBench.php --report=aggregate",
    "bench:baseline": "vendor/bin/phpbench run benchmarks/AuditBench.php --report=aggregate --tag=before --store",
    "bench:compare": "vendor/bin/phpbench run benchmarks/AuditBench.php --report=aggregate --ref=before --progress=plain",
    "bench:html": "vendor/bin/phpbench run benchmarks/AuditBench.php --report=aggregate --ref=before --output=html_file",
    "profile": "php benchmarks/profile.php",
    "update-tools": "composer update --working-dir=tools/php-cs-fixer ; composer update --working-dir=tools/phpstan ; composer update --working-dir=tools/rector"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "phpstan/extension-installer": true,
      "symfony/flex": true
    }
  },
  "extra": {
    "branch-alias": {
      "dev-main": "2.x-dev",
      "dev-1.x": "1.x-dev"
    }
  }
}
